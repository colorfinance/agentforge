# AI Skills Marketplace Configuration

# Database
DATABASE_PATH=./data/marketplace.db

# Server
PORT=3000
NODE_ENV=development

# JWT Secret (generate random string)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Stripe (for fiat payments)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Crypto Payments
CRYPTO_WALLET_ADDRESS=0x6BB903FD399E321cF3075d65a73909F300B01A24
CRYPTO_CURRENCY=USDT

# OpenClaw Execution
OPENCLAW_ENABLED=true
EXECUTION_TIMEOUT_MS=300000
MAX_RETRIES=1

# Marketplace Settings
PLATFORM_FEE_PERCENT=10
MIN_PRICE=0.50
MAX_PRICE=10000

# Categories
CATEGORIES=productivity,marketing,research,development,finance,design,writing,data